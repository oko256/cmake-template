{
  "problemMatcher": [
    {
      "owner": "cppcheck",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error|style|performance|portability|information):\\s+(.+?)\\s+\\[(.+)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5,
          "code": 6
        }
      ]
    }
  ]
}
