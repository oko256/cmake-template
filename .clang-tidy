---
# Reasoning for the disabled checks:
# - modernize-use-trailing-return-type
#     Completely stylistic choice. I don't think trailing return types are any easier to read.
# - readability-else-after-return
#     A stylistic choice, but to me it makes it easier to reason what the thought process was
#     if elses are used even when not necessarily needed.
# - readability-identifier-length
#     In very limited scopes, I think it's fine to have short variable names.
# - misc-include-cleaner
#     Sometimes it is impossible to make this check happy about the includes...
# - misc-non-private-member-variables-in-classes
#     Composition structs can be made of solely public member variables, and protected variables
#     are also useful in many cases.
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  clang-diagnostic-*,
  concurrency-*,
  cppcoreguidelines-*,
  hicpp-*,
  cert-*,
  modernize-*,-modernize-use-trailing-return-type,
  readability-*,-readability-else-after-return,-readability-identifier-length,
  readability-identifier-naming,
  performance-*,
  misc-*,-misc-include-cleaner,-misc-non-private-member-variables-in-classes

CheckOptions:
  # Identifier naming conventions
  # Type declarations (classes, structs, unions, enums)
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.UnionCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  # Type aliasing (using MyType = int)
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  # Enum value/constant declarations (scoped enums are highly preferred)
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key: readability-identifier-naming.ScopedEnumConstantCase
    value: CamelCase
  # Private/protected members
  - key: readability-identifier-naming.ProtectedMemberPrefix
    value: m_
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m_
  # Global variables
  - key: readability-identifier-naming.GlobalVariablePrefix
    value: g_
  # Namespaces
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  # Macros
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  # Templates
  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase

# Use style from .clang-format when suggesting fixes.
FormatStyle: file
