{
  "version": 8,
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ci",
      "displayName": "CI",
      "description": "CI configuration with most sanitizers, static analysis, and testing coverage",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "x_NAME_x_BUILD_TESTING": "ON",
        "x_NAME_x_COVERAGE": "ON",
        "x_NAME_x_DEVELOPER_MODE": "ON",
        "x_NAME_x_SA_CLANG_TIDY": "ON",
        "x_NAME_x_SA_CPPCHECK": "ON",
        "x_NAME_x_SA_CPPCHECK_EXH": "OFF",
        "x_NAME_x_SA_IWYU": "OFF",
        "x_NAME_x_SANITIZER_ADDRESS": "ON",
        "x_NAME_x_SANITIZER_LEAK": "ON",
        "x_NAME_x_SANITIZER_UNDEFINED": "ON",
        "x_NAME_x_SANITIZER_THREAD": "OFF",
        "x_NAME_x_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "ci-tsan",
      "displayName": "CI-TSan",
      "description": "Extra CI configuration with only TSan",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "x_NAME_x_BUILD_TESTING": "ON",
        "x_NAME_x_COVERAGE": "OFF",
        "x_NAME_x_DEVELOPER_MODE": "ON",
        "x_NAME_x_SA_CLANG_TIDY": "OFF",
        "x_NAME_x_SA_CPPCHECK": "OFF",
        "x_NAME_x_SA_CPPCHECK_EXH": "OFF",
        "x_NAME_x_SA_IWYU": "OFF",
        "x_NAME_x_SANITIZER_ADDRESS": "OFF",
        "x_NAME_x_SANITIZER_LEAK": "OFF",
        "x_NAME_x_SANITIZER_UNDEFINED": "OFF",
        "x_NAME_x_SANITIZER_THREAD": "ON",
        "x_NAME_x_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build configuration",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ci",
      "configurePreset": "ci"
    },
    {
      "name": "ci-tsan",
      "configurePreset": "ci-tsan"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ci-tsan",
      "configurePreset": "ci-tsan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
